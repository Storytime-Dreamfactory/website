BFL_API_KEY=your_bfl_api_key_here
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
# Optionen:
# - mini   -> flux-2-klein-4b
# - flux-2-flex -> Fallback fuer allgemeine Bildgenerierung
# - flux-2-pro -> Standard fuer Conversation-Hero-Bilder
# - banana -> gemini-2.5-flash-image
# - openai -> gpt-image-1.5
# - chatgpt -> chatgpt-image-latest
CONVERSATION_IMAGE_MODEL=flux-2-pro
RUNTIME_INTENT_MODEL=gpt-5.4
RUNTIME_REFERENCE_SELECTOR_MODEL=gpt-5.4
RUNTIME_NEXT_SCENE_SUMMARY_MODEL=gpt-5.4
RUNTIME_ACTIVITY_STORY_SUMMARY_MODEL=gpt-5.4
DATABASE_URL=postgres://storytime:storytime@localhost:5433/storytime
AWS_REGION=eu-central-1
ACTIVITY_EVENTBRIDGE_ENABLED=false
ACTIVITY_EVENTBRIDGE_BUS_NAME=storytime-activity-bus
ACTIVITY_EVENTBRIDGE_SOURCE=storytime.activities
ACTIVITY_EVENTBRIDGE_DETAIL_TYPE_PREFIX=storytime.activity
ACTIVITY_EVENTBRIDGE_STRICT=false
# Realtime-Events (Schritt 1 EventBridge Backbone)
REALTIME_EVENTBRIDGE_ENABLED=false
REALTIME_EVENTBRIDGE_BUS_NAME=
REALTIME_EVENTBRIDGE_SOURCE=storytime.realtime
REALTIME_EVENTBRIDGE_DETAIL_TYPE_PREFIX=storytime.voice
REALTIME_EVENTBRIDGE_STRICT=false
# Optional für LocalStack/Tests:
# ACTIVITY_EVENTBRIDGE_ENDPOINT=http://localhost:4566
# REALTIME_EVENTBRIDGE_ENDPOINT=http://localhost:4566

# Optional: Lokal gegen die produktiven API-Endpunkte entwickeln.
# true  -> Vite proxyt /api, /health, /ready gegen STORYTIME_REMOTE_API_ORIGIN
# false -> lokale Vite-API-Plugins (Default)
STORYTIME_USE_REMOTE_APIS=false
STORYTIME_REMOTE_API_ORIGIN=https://da64uvv5aj.execute-api.eu-central-1.amazonaws.com

# -------------------------------
# Empfohlene Profile
# -------------------------------
# local-full (default):
# STORYTIME_USE_REMOTE_APIS=false
# OPENAI_API_KEY=<required>
# BFL_API_KEY=<required>
# DATABASE_URL=postgres://storytime:storytime@localhost:5433/storytime
#
# local-remote-api:
# STORYTIME_USE_REMOTE_APIS=true
# STORYTIME_REMOTE_API_ORIGIN=https://da64uvv5aj.execute-api.eu-central-1.amazonaws.com
