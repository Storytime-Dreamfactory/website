BFL_API_KEY=your_bfl_api_key_here
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
# Optionen:
# - mini   -> flux-2-klein-4b
# - flux-2-flex -> empfohlen fuer gutes Tempo bei guter Qualitaet
# - banana -> gemini-2.5-flash-image
# - openai -> gpt-image-1.5
# - chatgpt -> chatgpt-image-latest
CONVERSATION_IMAGE_MODEL=flux-2-flex
RUNTIME_INTENT_MODEL=gpt-5.4
RUNTIME_REFERENCE_SELECTOR_MODEL=gpt-5.4
RUNTIME_NEXT_SCENE_SUMMARY_MODEL=gpt-5.4
RUNTIME_ACTIVITY_STORY_SUMMARY_MODEL=gpt-5.4
DATABASE_URL=postgres://storytime:storytime@localhost:5433/storytime
