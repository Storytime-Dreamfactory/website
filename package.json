{
  "name": "website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preflight:env": "node --env-file=.env --import tsx ./scripts/preflight-env.ts",
    "preflight:env:dev": "npm run preflight:env -- --mode=auto",
    "preflight:env:local-full": "npm run preflight:env -- --mode=local-full",
    "preflight:env:local-remote-api": "npm run preflight:env -- --mode=local-remote-api",
    "preflight:env:production-smoke": "npm run preflight:env -- --mode=production-smoke",
    "dev": "npm run preflight:env:dev && vite",
    "dev:local": "npm run preflight:env:local-full && vite",
    "dev:remote-api": "npm run preflight:env:local-remote-api && vite",
    "dev:lan": "vite --host",
    "quality:local": "npm run preflight:env:dev && npm run lint && npm run test && npm run build",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "character-images:dry-run": "node --env-file=.env --import tsx ./tools/character-image-service/src/cli.ts --dry-run",
    "character-images:generate": "node --env-file=.env --import tsx ./tools/character-image-service/src/cli.ts",
    "artifact-images:dry-run": "node --env-file=.env --import tsx ./tools/artifact-image-service/src/cli.ts --dry-run",
    "artifact-images:generate": "node --env-file=.env --import tsx ./tools/artifact-image-service/src/cli.ts",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose stop postgres",
    "db:init-relationships": "node --env-file=.env --import tsx ./scripts/create-character-relationships-table.ts",
    "db:seed-relationships": "node --env-file=.env --import tsx ./scripts/seed-character-relationships.ts",
    "db:query-relationships": "node --env-file=.env --import tsx ./scripts/query-character-relationships.ts",
    "db:migrate-relationship-uuids": "node --env-file=.env --import tsx ./scripts/migrate-relationship-slugs-to-uuids.ts",
    "db:standardize-relationship-labels": "node --env-file=.env --import tsx ./scripts/standardize-relationship-labels.ts",
    "db:backfill-activity-images": "node --env-file=.env --import tsx ./scripts/backfill-activity-image-assets.ts",
    "db:backfill-story-summaries": "node --env-file=.env --import tsx ./scripts/backfill-activity-story-summaries.ts",
    "db:backfill-story-summaries:dry-run": "node --env-file=.env --import tsx ./scripts/backfill-activity-story-summaries.ts --dry-run",
    "db:backfill-story-summaries:force": "node --env-file=.env --import tsx ./scripts/backfill-activity-story-summaries.ts --force",
    "content:deploy:aws": "./scripts/deploy-content-to-aws.sh",
    "deploy:smoke": "npm run preflight:env:production-smoke --",
    "deploy:smoke:basic": "./scripts/deploy-smoke-check.sh",
    "character-creation:smoke": "node --env-file=.env --import tsx ./scripts/character-creation-smoke.ts",
    "runtime:smoke": "node --env-file=.env --import tsx ./scripts/runtime-conversation-smoke.ts",
    "character-images:smoke-eval": "node --env-file=.env --import tsx ./scripts/character-image-eval-smoke.ts",
    "eval:self": "node --env-file=.env --import tsx ./src/server/eval/selfEvaluationCli.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@aws-sdk/client-eventbridge": "^3.1009.0",
    "antd": "^6.3.1",
    "leaflet": "^1.9.4",
    "leaflet.glify": "^3.3.1",
    "openai": "^6.27.0",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.1",
    "sharp": "^0.34.5",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
